<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_booking_flow"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#152238"
        app:titleTextColor="#FFFFFF" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/step_movie"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="1. Movie"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/step_time"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="2. Time"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/step_seat"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="3. Seat"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/step_confirm"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="4. Confirm"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/step_done"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="5. Done"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layout_step_movie"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bước 1: Booking Movie List"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#152238"
                android:layout_marginBottom="12dp" />

            <ProgressBar
                android:id="@+id/progress_movies"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_movies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_movies_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Không có phim nào"
                android:textColor="#6B7280"
                android:gravity="center"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_step_time"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bước 2: Booking Time"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#152238"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thời gian có sẵn"
                        android:textStyle="bold"
                        android:textColor="#111827" />

                    <ProgressBar
                        android:id="@+id/progress_showtimes"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_showtimes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_showtimes_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Không có suất chiếu"
                        android:textColor="#6B7280"
                        android:gravity="center"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_step_seat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bước 3: Chọn Ghế"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#152238"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:tag="seats_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chưa chọn ghế"
                        android:textColor="#1F2937"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:tag="seat_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0 VNĐ"
                        android:textColor="#065F46"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <ProgressBar
                        android:tag="progress_seats"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:tag="rv_seats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:tag="seats_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Không có ghế"
                        android:textColor="#6B7280"
                        android:gravity="center"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_step_confirm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bước 4: Đồ Ăn &amp; Xác Nhận"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#152238"
                android:layout_marginBottom="12dp" />

            <!-- Content will be added dynamically by code -->
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_step_payment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bước 5: Thanh Toán"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#152238"
                android:layout_marginBottom="12dp" />

            <!-- Content will be added dynamically by code -->
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_step_done"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <!-- Content will be added dynamically by code -->
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btn_previous_step"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Quay lại"
            android:background="#E5E7EB"
            android:textColor="#152238" />

        <Button
            android:id="@+id/btn_next_step"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Tiếp tục"
            android:background="#34D399"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
